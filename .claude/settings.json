{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Tipp: mit /uni:start beginnen - laedt Stand, Regeln und Git-Status.\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"__UNI_HOOKS_DIR__/fact-forcing-gate.js\"", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node \"__UNI_HOOKS_DIR__/fact-forcing-gate.js\"", "timeout": 5 }
        ]
      }
    ]
  }
}
