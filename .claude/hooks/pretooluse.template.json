{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"__UNI_HOOKS_DIR__/fact-forcing-gate.js\"", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node \"__UNI_HOOKS_DIR__/fact-forcing-gate.js\"", "timeout": 5 }
        ]
      }
    ]
  }
}
